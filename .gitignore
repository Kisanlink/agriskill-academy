# =============================================================================
# ASA Backend - Comprehensive .gitignore
# =============================================================================

# =============================================================================
# Go Language Specific
# =============================================================================

# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (remove the comment below to include it)
vendor/

# Go workspace file
go.work
go.work.sum

# Go build cache
go-build/

# =============================================================================
# Project Specific Build Artifacts
# =============================================================================

# Application binaries
main
server
asa
asa.exe
asa-linux
asa-mac
asa-windows.exe

# Build directory
build/
dist/
bin/

# Binary files in cmd directory
cmd/server/main
cmd/server/main.exe

# =============================================================================
# Environment and Configuration Files
# =============================================================================

# Environment files (contains sensitive data)
.env
.env.local
.env.development
.env.example
.env.production
.env.staging
.env.test
.env.backup

# Configuration files with sensitive data
config.local.json
config.production.json
config.staging.json
secrets.json
credentials.json

# =============================================================================
# Database and Migration Files
# =============================================================================

# Database dumps and backups
*.sql.bak
*.sql.backup
*.dump
*.backup

# Test database files
test.db
test.sqlite
test.sqlite3

# Migration test files
test_*.sql
debug_*.sql
fix_*.sql

# =============================================================================
# Upload and File Storage
# =============================================================================

# Upload directories (user-uploaded content)
uploads/
uploads/*
!uploads/.gitkeep

# File uploads
uploads/resumes/
uploads/certificates/
uploads/documents/
uploads/images/
uploads/temp/

# Temporary upload files
*.tmp
*.temp
temp_*
tmp_*

# =============================================================================
# Logs and Debug Files
# =============================================================================

# Log files
*.log
logs/
*.log.*
*.log.bak

# Debug files
debug_*
debug.log
debug.out

# Application logs
app.log
server.log
error.log
access.log

# =============================================================================
# IDE and Editor Files
# =============================================================================

# Visual Studio Code
.vscode/
.vscode/settings.json
.vscode/launch.json
.vscode/tasks.json
.vscode/extensions.json
.claude

# JetBrains IDEs (GoLand, IntelliJ IDEA, etc.)
.idea/
*.iml
*.ipr
*.iws

# Sublime Text
*.sublime-workspace
*.sublime-project

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp
.\#*

# =============================================================================
# Operating System Files
# =============================================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.tmp
*.temp
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# =============================================================================
# Testing and Coverage
# =============================================================================

# Test coverage files
*.coverprofile
*.coverage
coverage.out
coverage.html
coverage.xml

# Test results
test-results/
test-output/
junit.xml

# =============================================================================
# Archives and Compressed Files
# =============================================================================

# Archive files
*.tar
*.tar.gz
*.tar.bz2
*.tar.xz
*.tgz
*.zip
*.rar
*.7z
*.gz
*.bz2
*.xz

# =============================================================================
# Temporary and Cache Files
# =============================================================================

# Temporary files
*.tmp
*.temp
temp/
tmp/

# Cache directories
.cache/
cache/
*.cache

# Go module cache
go-mod-cache/

# =============================================================================
# Development and Debug Files
# =============================================================================

# Debug files
debug_*
*.debug

# Development files
dev_*
development_*

# Sample and test data
sample_*
seed_*
test_data/
debug_data/
fixtures/

# =============================================================================
# Deployment and CI/CD
# =============================================================================

# Deployment files
deploy/
deployment/
*.deploy
*.deployment

# Docker files (if using Docker)
Dockerfile.local
docker-compose.override.yml
.dockerignore

# Kubernetes files
*.kubeconfig
kubeconfig

# =============================================================================
# Security and Secrets
# =============================================================================

# Private keys and certificates
*.pem
*.key
*.crt
*.cert
*.p12
*.pfx

# SSH keys
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub

# =============================================================================
# Scripts and Automation
# =============================================================================

# PowerShell execution policy bypass files
*.ps1.bak
*.ps1.tmp

# Shell script backups
*.sh.bak
*.sh.tmp

# =============================================================================
# Documentation and Notes
# =============================================================================

# Documentation drafts
docs/draft/
docs/temp/

# Notes and todos
TODO.md
NOTES.md
CHANGELOG.md
*.todo
*.note
API_DOCUMENTATION.md
FIREBASE_EMAIL_SETUP.md
FIREBASE_API_KEY_SETUP.md
API_CHANGES_EMAIL_VERIFICATION.md
API_CHANGES.md
FRONTEND_API_REFERENCE.md
test-agriskill-api.ps1
docker-compose.yml
CLAUDE.md

# =============================================================================
# Backup and Recovery
# =============================================================================

# Backup files
*.bak
*.backup
*.old
*.orig

# Recovery files
*.recovery
*.restore

# =============================================================================
# Monitoring and Metrics
# =============================================================================

# Metrics and monitoring files
metrics/
monitoring/
*.metrics
*.monitoring

# =============================================================================
# Air (Hot Reload) Configuration
# =============================================================================

# Air configuration
.air.toml
air.toml

# =============================================================================
# Keep Important Directories
# =============================================================================

# Keep uploads directory structure but ignore contents
!uploads/
uploads/*
!uploads/.gitkeep

# Keep migrations directory
!migrations/
!scripts/

# Keep documentation
!docs/
!README.md
!CHANGELOG.md
!LICENSE
serviceAccountKey.json