# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DB_HOST=
DB_PORT=
POSTGRESS_USER=
POSTGRESS_PASS=
DB_NAME=
DB_SSLMODE=

# =============================================================================
# AUTHENTICATION
# =============================================================================
JWT_SECRET=

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
SERVER_PORT=
GIN_MODE=release

# =============================================================================
# AWS S3 / MINIO CONFIGURATION
# =============================================================================
AWS_REGION=
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_ENDPOINT=
AWS_S3_FORCE_PATH_STYLE=
AWS_S3_DISABLE_SSL=

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
APP_NAME=
APP_VERSION=1.0.0
APP_ENV=release
ASA_BASE_URL=

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================
# Enable email notifications (set to "true" to enable)
EMAIL_NOTIFICATION=true

# SMTP Configuration
# For local testing with Mailpit (docker-compose):
#   MAIL_HOST=mailpit (or localhost if running Mailpit locally)
#   MAIL_PORT=1025
#   MAIL_FROM=noreply@agrijobs.com
#   MAIL_PASS=test (can be any value, Mailpit doesn't require authentication)
#
# For production SMTP (e.g., Gmail, SendGrid, AWS SES):
#   MAIL_HOST=smtp.gmail.com
#   MAIL_PORT=587
#   MAIL_FROM=your-email@gmail.com
#   MAIL_PASS=your-app-password
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_FROM=noreply@agrijobs.com
MAIL_PASS=test

# Email Logo URL (hosted on CDN/S3, not local)
# Example: https://your-cdn.com/logo.png
# Or use your API endpoint: https://yourdomain.com/api/files/serve/app-logo
EMAIL_LOGO_URL=

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m
CORS_ALLOWED_ORIGINS=
MAX_REQUEST_SIZE=10485760
ENABLE_CORS=true

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
LOG_LEVEL=info
LOG_FILE=
LOG_FORMAT=json
LOG_DEVELOPMENT=false

# =============================================================================
# REDIS CONFIGURATION (for job queue)
# =============================================================================
REDIS_ADDR=
REDIS_PASSWORD=
REDIS_DB=0

# =============================================================================
# HEALTH CHECK CONFIGURATION
# =============================================================================
HEALTH_CHECK_TIMEOUT=30s

# =============================================================================
# JOB QUEUE CONFIGURATION
# =============================================================================
JOB_MAX_RETRIES=3

# =============================================================================
# ADMIN SEEDING CONFIGURATION
# =============================================================================
ASA_RUN_SEED=
DEFAULT_ADMIN_EMAIL=
DEFAULT_ADMIN_PASSWORD=
DEFAULT_ADMIN_NAME=
DEFAULT_ADMIN_USERNAME=