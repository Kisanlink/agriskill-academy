# Database Configuration
DB_HOST=localhost
DB_PORT=5432
POSTGRES_USER=your_username
POSTGRES_PASS=your_password
DB_NAME=asa_db
DB_SSLMODE=disable

# JWT Configuration
SECRET_KEY=your_jwt_secret_key_here_make_it_long_and_secure

# Server Configuration
PORT=3333
GIN_MODE=debug

# CORS Configuration
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_DIR=uploads

# Email Configuration (for password reset - mock implementation)
MAIL_FROM=your_email@gmail.com
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_PASS=your_app_password

# AWS S3 Configuration (Required for file storage)
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-s3-bucket-name
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_ENDPOINT=
AWS_S3_FORCE_PATH_STYLE=false
AWS_S3_DISABLE_SSL=false

# Application Configuration
APP_NAME=ASA Job Portal
APP_VERSION=1.0.0
APP_ENV=development
ASA_BASE_URL=http://localhost:3000/api

# Logging Configuration
LOG_LEVEL=debug
LOG_FILE=logs/app.log

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=15m
